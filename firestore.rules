rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Group config doc (openAt/closeAt): admin creates it in Firebase Console.
    // Clients may read it to show the ordering window, never write it.
    match /groups/{groupId} {
      allow read: if true;
      allow write: if false;
    }

    match /groups/{groupId}/orders/{orderId} {
      function groupPath() {
        return /databases/$(database)/documents/groups/$(groupId);
      }
      // Groups without a config doc stay always-open (backward compatible)
      function withinOrderWindow() {
        return !exists(groupPath())
          || (
            (!('openAt' in get(groupPath()).data) || get(groupPath()).data.openAt <= request.time)
            && (!('closeAt' in get(groupPath()).data) || request.time <= get(groupPath()).data.closeAt)
          );
      }

      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 'drink', 'img', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.drink is string
        && request.resource.data.drink.size() > 0
        && request.resource.data.drink.size() <= 120
        && request.resource.data.img is string
        && request.resource.data.img.size() <= 1000
        && request.resource.data.createdAt == request.time
        && withinOrderWindow();
      allow update, delete: if false;
    }
  }
}
