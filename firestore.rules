rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Group config doc (openAt/closeAt): the organizer creates it once from
    // the page UI; after that it is locked (no update/delete), so latecomers
    // cannot move the deadline.
    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['openAt', 'closeAt', 'members', 'menuItems', 'createdAt'])
        && request.resource.data.openAt is timestamp
        && request.resource.data.closeAt is timestamp
        && request.resource.data.closeAt > request.resource.data.openAt
        && (!('members' in request.resource.data)
          || (request.resource.data.members is list
            && request.resource.data.members.size() > 0
            && request.resource.data.members.size() <= 200))
        && (!('menuItems' in request.resource.data)
          || (request.resource.data.menuItems is list
            && request.resource.data.menuItems.size() > 0
            && request.resource.data.menuItems.size() <= 50))
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /groups/{groupId}/orders/{orderId} {
      function groupPath() {
        return /databases/$(database)/documents/groups/$(groupId);
      }
      // Groups without a config doc stay always-open (backward compatible)
      function withinOrderWindow() {
        return !exists(groupPath())
          || (
            (!('openAt' in get(groupPath()).data) || get(groupPath()).data.openAt <= request.time)
            && (!('closeAt' in get(groupPath()).data) || request.time <= get(groupPath()).data.closeAt)
          );
      }
      // Groups with a member list only accept orders under listed names
      function nameAllowed() {
        return !exists(groupPath())
          || !('members' in get(groupPath()).data)
          || request.resource.data.name in get(groupPath()).data.members;
      }

      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 'drink', 'img', 'batch', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.drink is string
        && request.resource.data.drink.size() > 0
        && request.resource.data.drink.size() <= 120
        && request.resource.data.img is string
        && request.resource.data.img.size() <= 1000
        && (!('batch' in request.resource.data)
          || (request.resource.data.batch is string
            && request.resource.data.batch.size() > 0
            && request.resource.data.batch.size() <= 60))
        && request.resource.data.createdAt == request.time
        && withinOrderWindow()
        && nameAllowed();
      allow update, delete: if false;
    }
  }
}
